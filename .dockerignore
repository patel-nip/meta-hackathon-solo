# ── Version control ───────────────────────────────────────────────────────────
.git
.gitignore

# ── Python artifacts ──────────────────────────────────────────────────────────
__pycache__
*.pyc
*.pyo
*.egg-info
dist/
build/
.eggs/

# ── Virtual environments ─────────────────────────────────────────────────────
.venv
venv
env

# ── Lock files (not needed at runtime) ────────────────────────────────────────
uv.lock

# ── IDE / editor ─────────────────────────────────────────────────────────────
.vscode
.idea
*.swp
*.swo

# ── Documentation (not needed in container) ──────────────────────────────────
*.md
!README.md

# ── Test files ────────────────────────────────────────────────────────────────
test_*.py
tests/
